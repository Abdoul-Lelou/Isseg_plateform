datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ----------------------------------------------------
// ENUMS
// ----------------------------------------------------

enum StatutPaiement {
  EN_ATTENTE
  PARTIEL
  PAYE
}

enum StatutTransaction {
  INITIEE
  COMPLETEE
  ECHOUEE
  ANNULEE
}

enum StatutDossier {
  BROUILLON
  SOUMIS
  EN_TRAITEMENT
  ACCEPTE
  REJETE
}

enum DecisionScolarite {
  EN_ATTENTE
  ADMIS
  REFUSE
  LISTE_D_ATTENTE
}

enum StatutValidation {
  EN_ATTENTE
  APPROUVE
  REJETE
  A_REVISER
}

// ----------------------------------------------------
// 1. IDENTITÉ ET UTILISATEURS
// ----------------------------------------------------

model Utilisateur {
  id             String  @id @default(uuid())
  nom            String
  prenom         String
  email          String  @unique
  motDePasseHash String
  estActif       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roles     UtilisateurRole[]
  etudiant  Etudiant?
  personnel Personnel?
  parent    Parent?
}

model Role {
  id      String @id @default(uuid())
  nomRole String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  utilisateurs UtilisateurRole[]
  permissions  RolePermission[]
}

model Permission {
  id            String  @id @default(uuid())
  nomPermission String  @unique
  description   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roles RolePermission[]
}

model UtilisateurRole {
  utilisateurId String
  roleId        String

  createdAt DateTime @default(now())

  utilisateur Utilisateur @relation(fields: [utilisateurId], references: [id])
  role        Role        @relation(fields: [roleId], references: [id])

  @@id([utilisateurId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String

  createdAt DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

// ----------------------------------------------------
// 2. PERSONNEL ET STRUCTURE
// ----------------------------------------------------

model Personnel {
  id           String   @id @default(uuid())
  userId       String   @unique
  matricule    String   @unique
  poste        String
  dateEmbauche DateTime
  salaire      Decimal

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  utilisateur Utilisateur @relation(fields: [userId], references: [id])

  departementId String?
  departement   Departement? @relation("PersonnelDepartement", fields: [departementId], references: [id])

  departementDirige Departement? @relation("DepartementDirecteur")

  fraisEnregistres FraisScolarite[] @relation("FraisEnregistreur")

  enseignant  Enseignant?
  responsable ResponsablePedagogique?
}

model Departement {
  id          String @id @default(uuid())
  code        String @unique
  nom         String
  description String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  directeurId String?    @unique
  directeur   Personnel? @relation("DepartementDirecteur", fields: [directeurId], references: [id])

  personnels Personnel[] @relation("PersonnelDepartement")
}

// ----------------------------------------------------
// 3. ÉTUDIANTS, SCOLARITÉ ET PARAMÉTRAGE
// ----------------------------------------------------

model AnneeUniversitaire {
  id        String   @id @default(uuid())
  libelle   String   @unique
  dateDebut DateTime
  dateFin   DateTime
  estActive Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inscriptions        Inscription[]
  fraisScolarite      FraisScolarite[]
  dossiersInscription DossierInscription[]
}

model Etudiant {
  id              String        @id @default(uuid())
  userId          String        @unique
  matriculeUnique String        @unique
  dateNaissance   DateTime
  telephone       String?
  statutDossier   StatutDossier @default(BROUILLON)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  utilisateur Utilisateur @relation(fields: [userId], references: [id])

  dossiers     DossierInscription[]
  inscriptions Inscription[]
  carnetSuivi  CarnetSuivi?

  parents Parent[] @relation("ParentEtudiant")
}

model DossierInscription {
  id                String            @id @default(uuid())
  etudiantId        String
  anneeId           String
  documentsFournis  String[]
  decisionScolarite DecisionScolarite @default(EN_ATTENTE)
  dateSoumission    DateTime          @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  etudiant           Etudiant           @relation(fields: [etudiantId], references: [id])
  anneeUniversitaire AnneeUniversitaire @relation(fields: [anneeId], references: [id])

  @@unique([etudiantId, anneeId])
}

model Classe {
  id         String @id @default(uuid())
  codeClasse String @unique
  libelle    String
  niveau     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inscriptions Inscription[]
}

model Inscription {
  id              String   @id @default(uuid())
  etudiantId      String
  classeId        String
  anneeId         String
  dateInscription DateTime @default(now())
  estActive       Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  etudiant           Etudiant           @relation(fields: [etudiantId], references: [id])
  classe             Classe             @relation(fields: [classeId], references: [id])
  anneeUniversitaire AnneeUniversitaire @relation(fields: [anneeId], references: [id])

  frais FraisScolarite?

  @@unique([etudiantId, anneeId])
}

// ----------------------------------------------------
// 4. FINANCE
// ----------------------------------------------------

model FraisScolarite {
  id              String         @id @default(uuid())
  inscriptionId   String         @unique
  enregistreParId String
  anneeId         String
  montantTotal    Decimal
  montantPaye     Decimal
  statutPaiement  StatutPaiement @default(EN_ATTENTE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inscription        Inscription        @relation(fields: [inscriptionId], references: [id])
  enregistrePar      Personnel          @relation("FraisEnregistreur", fields: [enregistreParId], references: [id])
  anneeUniversitaire AnneeUniversitaire @relation(fields: [anneeId], references: [id])

  transactions Transaction[]
}

model Transaction {
  id              String            @id @default(uuid())
  fraisId         String
  referenceUnique String            @unique
  montant         Decimal
  dateTransaction DateTime          @default(now())
  modePaiement    String
  statut          StatutTransaction @default(INITIEE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  frais FraisScolarite @relation(fields: [fraisId], references: [id])

  @@index([fraisId])
}

// ----------------------------------------------------
// 5. PÉDAGOGIE
// ----------------------------------------------------

model Enseignant {
  id          String @id @default(uuid())
  personnelId String @unique
  specialite  String
  grade       String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  personnel Personnel @relation(fields: [personnelId], references: [id])

  coursScenarises CoursScenarise[]
  evaluations     Evaluation[]
}

model ResponsablePedagogique {
  id          String @id @default(uuid())
  personnelId String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  personnel Personnel @relation(fields: [personnelId], references: [id])

  validations ValidationCours[]
}

model CoursScenarise {
  id                    String           @id @default(uuid())
  enseignantId          String
  titre                 String
  codeCours             String           @unique
  description           String
  objectifsPedagogiques String
  statutValidation      StatutValidation @default(EN_ATTENTE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enseignant Enseignant @relation(fields: [enseignantId], references: [id])

  evaluations Evaluation[]
  validations ValidationCours[]
}

model ValidationCours {
  id             String           @id @default(uuid())
  coursId        String
  responsableId  String
  dateValidation DateTime         @default(now())
  statut         StatutValidation @default(EN_ATTENTE)
  commentaire    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cours       CoursScenarise         @relation(fields: [coursId], references: [id])
  responsable ResponsablePedagogique @relation(fields: [responsableId], references: [id])
}

model Evaluation {
  id            String   @id @default(uuid())
  coursId       String
  correcteurId  String
  codeAnonymat  String   @unique
  noteOriginale Decimal
  noteAjustee   Decimal?
  estAnonyme    Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cours      CoursScenarise @relation(fields: [coursId], references: [id])
  correcteur Enseignant     @relation(fields: [correcteurId], references: [id])
}

// ----------------------------------------------------
// 6. PORTAIL PARENT
// ----------------------------------------------------

model Parent {
  id               String @id @default(uuid())
  userId           String @unique
  lienParente      String
  telephoneContact String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  utilisateur Utilisateur @relation(fields: [userId], references: [id])

  etudiantsCharge  Etudiant[]    @relation("ParentEtudiant")
  carnetsConsultes CarnetSuivi[] @relation("ParentCarnet")
  messages         Message[]
}

model CarnetSuivi {
  id                   String   @id @default(uuid())
  etudiantId           String   @unique
  moyenneGenerale      Decimal?
  tauxAbsences         Int      @default(0)
  appreciationGenerale String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  etudiant Etudiant @relation(fields: [etudiantId], references: [id])

  parentsSpectateurs Parent[] @relation("ParentCarnet")
}

model Message {
  id       String @id @default(uuid())
  parentId String
  objet    String
  contenu  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent Parent @relation(fields: [parentId], references: [id])
}
